# MAF example environment file
# Copy to .env and fill in real values. Never commit .env.

TZ=America/New_York
DATA_DIR=/data
DB_PATH=/data/history.db

# Disable setup UI in production after configuration.
DISABLE_SETUP=1

# Recommended production mode: qBittorrent downloads to its own configured
# default folder and Audiobookshelf scans that same folder. MAF only requests.
LIBRARY_MODE=qbit_abs_shared
ENABLE_IMPORT=0

# MAM credential. Accepts either a full Cookie header or mam_id=<value>.
MAM_COOKIE=replace_me
MAM_BASE=https://www.myanonamouse.net

# qBittorrent Web UI URL reachable from the MAF container.
QB_URL=http://qbittorrent:8080
QB_USER=replace_me
QB_PASS=replace_me

# Leave blank to use qBittorrent's configured default save path.
QB_SAVEPATH=
QB_CATEGORY=maf
QB_TAGS=MAM,audiobook,maf

# Freeleech Wedge policy: off | always | smart
WEDGE_MODE=smart
WEDGE_UNKNOWN_FALLBACK=true

# Optional Audiobookshelf history resolver.
ABS_URL=
ABS_TOKEN=
ABS_LIBRARY_ID=
ABS_DIRECT_ITEM_URLS=false

# Legacy/import settings. Leave these alone for the qBit+ABS shared-folder flow.
DL_DIR=/media/torrents
LIB_DIR=/media/audiobookshelf
IMPORT_MODE=link
QB_INNER_DL_PREFIX=/downloads
QB_PATH_MAP=
QB_POSTIMPORT_CATEGORY=

PUID=1000
PGID=1000
UMASK=0002
